# GEMINI_API_KEY: Required for Gemini AI API calls.
# Set this to your Google Gemini API key for AI responses.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# ENVIRONMENT CONFIG
NODE_ENV=development
PORT=3000

JWT_SECRET=
COOKIE_SECRET=

# GOOGLE_MAPS_PLATFORM_KEY: Required for Google Maps and Places Autocomplete search.
GOOGLE_MAPS_PLATFORM_KEY=
VITE_GOOGLE_MAPS_PLATFORM_KEY=

# RAZORPAY_KEY_ID: Razorpay API Key ID for live checkout or testing transactions.
RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET: Razorpay API Key Secret used to cryptographically sign/verify payments.
RAZORPAY_KEY_SECRET=

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL=
VITE_SUPABASE_URL=

# SUPABASE_API_KEY / KEYS: The API/Service/Anon key for your Supabase project.
SUPABASE_API_KEY=
VITE_SUPABASE_API_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_ANON_KEY=

SUPABASE_JWKS_URL=


