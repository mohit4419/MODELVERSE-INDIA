{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "overrides": {
    "node-domexception": "file:./mocks/node-domexception"
  },
  "scripts": {
    "dev": "tsx server/index.ts",
    "build:frontend": "vite build",
    "build:backend": "esbuild server/index.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist-server/index.cjs",
    "build": "npm run build:frontend && npm run build:backend",
    "start": "node dist-server/index.cjs",
    "clean": "rm -rf dist dist-server server.js",
    "lint": "tsc --noEmit"
  },
