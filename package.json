    "@types/ws": "^8.18.1",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "html5-qrcode": "^2.3.8",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "morgan": "^1.11.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "razorpay": "^2.9.6",
    "react": "^19.0.1",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.0.1",
    "stripe": "^22.3.0",
    "vite": "^6.2.3",
    "ws": "^8.21.0",
